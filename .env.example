# Google Gemini API Configuration
# Dapatkan API key dari: https://aistudio.google.com/app/apikey
# JANGAN PERNAH push file .env yang berisi API key asli!
GEMINI_API_KEY=your_api_key_here_replace_with_actual_key

# ChromaDB Configuration
CHROMA_DB_PATH=./my_vector_db

# System Configuration
COLLECTION_NAME=sustainable_transport
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K_RESULTS=3

# Embedding Model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

